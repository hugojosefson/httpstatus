{
  "name": "@hugojosefson/httpstatus",
  "version": "0.1.0",
  "description": "A reimplementation of https://httpstat.us",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "dev": "deno run --allow-net src/main.ts",
    "start": "deno run --allow-net src/main.ts",
    "check": "deno check src/ test/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test --allow-net test/",
    "all": "deno fmt && deno lint && deno check src/ test/ && deno test --allow-net test/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/http": "jsr:@std/http@^1.0.25"
  },
  "deploy": {
    "project": "af55b7fd-ea3f-49fc-9403-ac035c993fc2",
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "src/main.ts"
  }
}